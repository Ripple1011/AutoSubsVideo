# Copy to .env.production for prod builds, or .env.local for local-only testing.
# These are PUBLIC keys -- they only authorize event ingestion, not data read.

# PostHog product analytics. Without this set, analytics calls no-op.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Set to 1 if you want analytics events to fire during `npm run dev`.
# Default behavior is silent in dev so hot-reloads don't pollute the funnel.
VITE_POSTHOG_DEV=

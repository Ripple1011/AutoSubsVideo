[Unit]
Description=AutoSub FastAPI (Uvicorn)
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=autosub
WorkingDirectory=/home/autosub/autosub/backend
EnvironmentFile=/home/autosub/autosub/backend/.env
ExecStart=/home/autosub/autosub/backend/.venv/bin/uvicorn app.main:app \
    --host 127.0.0.1 --port 8000 --workers 2
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target

# AutoSub production env — copied to backend/.env by deploy/setup.sh.
# Edit values, then start the service: systemctl start autosub.

# ─── Shared-password gate ──────────────────────────────────────────────
# REQUIRED for any internet-reachable deploy. Picks something long and
# unguessable. Every visitor's browser prompts once; it's stored in
# their localStorage and sent on every API call. Skip endangering your
# Gemini quota by leaving this unset.
SHARED_PASSWORD=change-me-to-something-long-and-random

# ─── Server-side ASR fallback keys ─────────────────────────────────────
# Users supply their own keys via the Settings modal (BYOK) and those
# always win. These are only used when a request arrives without a
# user-supplied key — i.e., for casual visitors who haven't set up
# their own Gemini account. Leave blank to require BYOK from everyone.
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
SARVAM_API_KEY=

# Default provider + model used when neither the request nor the user
# specifies one. Match these to whichever key you actually filled in.
ASR_PROVIDER=gemini
ASR_MODEL=gemini-2.5-flash

# ─── Infra ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Keep CELERY disabled — the inline pipeline path is what's currently
# tested and what the deploy is configured for. Flip later if you wire
# up a separate worker.
CELERY_ENABLED=false

# ─── Limits + retention ────────────────────────────────────────────────
MAX_VIDEO_SECONDS=600        # 10-minute cap on individual uploads
RETENTION_DAYS=14            # auto-delete jobs older than this; 0 disables

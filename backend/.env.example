# AutoSub backend environment — copy to backend/.env and fill in.
# Per CLAUDE.md §4.3: these are SERVER DEFAULTS. User BYOK keys arrive via
# request headers and override these values at runtime.

# Which provider to use when no user header is supplied.
ASR_PROVIDER=groq                 # groq | openai | sarvam
ASR_MODEL=whisper-large-v3        # provider-scoped

# Supply the key matching ASR_PROVIDER above. Leave the others blank.
GROQ_API_KEY=
OPENAI_API_KEY=
SARVAM_API_KEY=                   # get from dashboard.sarvam.ai
GEMINI_API_KEY=                   # get from aistudio.google.com

# Celery broker / result backend.
REDIS_URL=redis://localhost:6379/0
CELERY_ENABLED=false              # flip to true after `celery -A app.tasks worker` is running

# Upload guardrails.
MAX_VIDEO_SECONDS=600             # 10 min personal cap
